[Unit]
Description=Bulk Affiliate Pipeline API
After=network.target docker.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/bulk-affiliate
ExecStart=/opt/bulk-affiliate/venv/bin/uvicorn deploy.pipeline_api:app --host 0.0.0.0 --port 5050
Restart=always
RestartSec=10
EnvironmentFile=/opt/bulk-affiliate/.env.cowork

[Install]
WantedBy=multi-user.target
